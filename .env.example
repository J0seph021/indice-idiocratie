# Copiez ce fichier en ".env" et remplissez UNE des deux clés.
# Sans clé, le script tourne en mode démo (dérive aléatoire des scores).

# --- Option A : Claude (recommandé, sur la marque) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Option B : OpenAI (le moins cher) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Forcer un provider : anthropic | openai | none
# LLM_PROVIDER=anthropic

# --- Réseaux sociaux (GitHub Secrets en prod, .env en dev) ---
# Facebook Page
META_PAGE_ID=1114398978432645
META_PAGE_ACCESS_TOKEN=

# Threads
THREADS_USER_ID=
THREADS_USER_TOKEN=

# Instagram Business
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# X/Twitter (à venir)
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=
